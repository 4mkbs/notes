# JWT Secret Key for signing tokens
# Generate a strong random string (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRES_IN=15m

# Comma-separated list of allowed frontend origins.
# Example: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Global API limit per 15-minute window.
RATE_LIMIT_MAX=200

# Server port for local development.
PORT=8000

# MongoDB Connection String
# Format: mongodb://localhost:27017/notesdb (local)
# Or: mongodb+srv://username:password@cluster.mongodb.net/notesdb (cloud)
CONNECTION_STRING=your_mongodb_connection_string_here